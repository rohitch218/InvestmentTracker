## 3. Entity Relationship Diagram (ERD)

```mermaid
erDiagram
    TENANTS {
        varchar(36)  id           PK
        varchar(100) name
        varchar(100) domain
        enum         plan
        boolean      is_active
        timestamp    created_at
    }

    USERS {
        bigint       id           PK
        varchar(36)  tenant_id    FK
        varchar(50)  username
        varchar(150) email
        varchar(255) password_hash
        enum         role
        boolean      is_active
        timestamp    created_at
    }

    INVESTMENTS {
        bigint       id           PK
        varchar(36)  tenant_id    FK
        bigint       user_id      FK
        varchar(150) name
        enum         type
        varchar(20)  symbol
        decimal      quantity
        decimal      purchase_price
        decimal      current_price
        date         purchase_date
        timestamp    deleted_at
    }

    TRANSACTIONS {
        bigint       id              PK
        varchar(36)  tenant_id       FK
        bigint       investment_id   FK
        bigint       user_id         FK
        enum         transaction_type
        decimal      quantity
        decimal      price
        date         transaction_date
        enum         source
    }

    AUDIT_LOGS {
        bigint       id          PK
        varchar(36)  tenant_id   FK
        bigint       user_id     FK
        varchar(50)  entity_type
        bigint       entity_id
        enum         action
        json         old_value
        json         new_value
        timestamp    occurred_at
    }

    TENANTS ||--o{ USERS        : "has many"
    TENANTS ||--o{ INVESTMENTS  : "has many"
    TENANTS ||--o{ TRANSACTIONS : "has many"
    TENANTS ||--o{ AUDIT_LOGS   : "has many"
    USERS   ||--o{ INVESTMENTS  : "owns"
    USERS   ||--o{ TRANSACTIONS : "performs"
    USERS   ||--o{ AUDIT_LOGS   : "generates"
    INVESTMENTS ||--o{ TRANSACTIONS : "has many"
```

